---
import MainLayout from '../layouts/MainLayout.astro';
import { getUser } from '../lib/auth';

const user = await getUser();

if (user) {
  return Astro.redirect('/');
}
---

<MainLayout title="Rexistru">
  <div class="max-w-md mx-auto mt-12">
    <div class="bg-white rounded-lg shadow-lg p-8">
      <h1 class="text-3xl font-bold text-[#2d5016] mb-6 text-center">Rexistru</h1>
      
      <form id="registerForm" class="space-y-4">
        <div>
          <label for="email" class="block text-sm font-semibold mb-2">Corréu electrónicu</label>
          <input
            type="email"
            id="email"
            name="email"
            required
            class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#2d5016] focus:border-transparent"
            placeholder="tu@correu.com"
          />
        </div>

        <div>
          <label for="password" class="block text-sm font-semibold mb-2">Contraseña</label>
          <input
            type="password"
            id="password"
            name="password"
            required
            minlength="6"
            class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#2d5016] focus:border-transparent"
            placeholder="Mínimu 6 caráuteres"
          />
        </div>

        <div>
          <label for="confirmPassword" class="block text-sm font-semibold mb-2">Confirmar contraseña</label>
          <input
            type="password"
            id="confirmPassword"
            name="confirmPassword"
            required
            minlength="6"
            class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#2d5016] focus:border-transparent"
            placeholder="Repite la contraseña"
          />
        </div>

        <button
          type="submit"
          class="w-full bg-[#2d5016] text-white py-3 rounded-lg font-semibold hover:bg-[#3d6026] transition-colors"
        >
          Rexistrase
        </button>
      </form>

      <div class="mt-6 text-center">
        <p class="text-gray-600">
          ¿Yá tienes cuenta?{' '}
          <a href="/login" class="text-[#2d5016] font-semibold hover:text-[#d4a574]">
            Anicia sesión
          </a>
        </p>
      </div>
    </div>
  </div>
</MainLayout>

<script>
  import { signUp } from '../lib/auth';

  const form = document.getElementById('registerForm') as HTMLFormElement;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    const formData = new FormData(form);
    const email = formData.get('email') as string;
    const password = formData.get('password') as string;
    const confirmPassword = formData.get('confirmPassword') as string;

    if (password !== confirmPassword) {
      alert('Les contraseñes nun coinciden');
      return;
    }

    if (password.length < 6) {
      alert('La contraseña tien que tener polo menos 6 caráuteres');
      return;
    }

    try {
      await signUp(email, password);
      alert('Rexistru esitosu. Agora pues aniciar sesión.');
      window.location.href = '/login';
    } catch (error) {
      alert('Error al rexistrase. Ye posible que\'l corréu yá tea n\'usu.');
    }
  });
</script>
